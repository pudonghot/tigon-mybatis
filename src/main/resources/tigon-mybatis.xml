<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC
    "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="Tigon">

    <!-- Search -->
    <sql id="search">
        <choose>
        <when test="__search__ instanceof com.pudonghot.tigon.mybatis.Search">
            <if test="__search__.hasCriterion()">
                where <include refid="Tigon.assemble" />
            </if>

            <if test="!_parameter.containsKey(&quot;__no_paging__&quot;)">
                <include refid="Tigon.orderBy" />
                <include refid="Tigon.limit" />
            </if>
        </when>
        <when test="__search__ != null">
            where <include refid="primaryKey" /> = #{__search__}
        </when>
        </choose>
    </sql>
    <!--/ Search -->

    <!-- Distinct -->
    <sql id="distinct">
        <if test="__search__ instanceof com.pudonghot.tigon.mybatis.Search and __search__.hasDistinct()">
            distinct
        </if>
    </sql>
    <!--/ Distinct -->

    <!-- Search Assemble -->
    <sql id="assemble">
        <foreach collection="__search__.assemble()" item="__val__">
            <include refid="Tigon.__val__" />
        </foreach>
    </sql>
    <!--/ Search Assemble -->

    <!-- Order By -->
    <sql id="orderBy">
        <if test="__search__.hasOrder()">
            order by
            <foreach collection="__search__.orders()" index="__col__"
                     item="__direction__" separator=", ">
                <choose>
                    <when test="__direction__ instanceof java.util.Collection">
                        field(${__col__},
                        <foreach collection="__direction__" item="__val__" separator=", ">
                            #{__val__}
                        </foreach>
                        )
                    </when>
                    <otherwise>
                        ${__col__} ${__direction__}
                    </otherwise>
                </choose>
            </foreach>
        </if>
    </sql>
    <!--/ Order By -->

    <!-- Limit -->
    <sql id="limit">
        <choose>
            <when test="__search__.offset() != null and __search__.limit() != null">
                <bind name="__offset__" value="__search__.offset()" />
                <bind name="__limit__" value="__search__.limit()" />
                limit #{__offset__}, #{__limit__}
            </when>
            <when test="__search__.limit() != null">
                <bind name="__limit__" value="__search__.limit()" />
                limit #{__limit__}
            </when>
        </choose>
    </sql>
    <!--/ Limit -->

    <!-- Mark query is no paging -->
    <sql id="noPaging">
        <bind name="__dummy_var_no_paging__" value="_parameter.put('__no_paging__', true)" />
    </sql>
    <!--/ Mark query is no paging -->

    <!-- No paging search -->
    <sql id="npSearch">
        <include refid="Tigon.noPaging" />
        <include refid="Tigon.search" />
    </sql>
    <!--/ No paging search -->

    <!-- Insert -->
    <sql id="insert">
        insert into <include refid="table" />
        (<include refid="cols" />)
        values
        <choose>
            <!-- Model -->
            <when test="_parameter.containsKey(&quot;__model__&quot;)">
                (<include refid="Tigon.modelValues" />)
            </when>
            <!-- Models -->
            <otherwise>
                <foreach item="__model__" collection="__models__" separator=", ">
                    (<include refid="Tigon.modelValues" />)
                </foreach>
            </otherwise>
        </choose>
    </sql>
    <!--/ Insert -->

    <sql id="modelValues">
        <if test="__model__ instanceof com.pudonghot.tigon.mybatis.BasicEntity">
            <bind name="__before_insert_dummy__" value="__model__.beforeInsert()" />
        </if>
        <foreach collection="@com.pudonghot.tigon.mybatis.util.EntityUtils@insertMap(__model__)"
                 item="__val__" separator=", ">
            <include refid="Tigon.__val__" />
        </foreach>
    </sql>

    <!-- Update -->
    <sql id="update">
        <choose>
            <when test="_parameter.containsKey(&quot;__models__&quot;)">
                <bind name="__first_update_map__" value="@com.pudonghot.tigon.mybatis.util.EntityUtils@batchUpdateMap(__models__.iterator().next())" />
                update <include refid="table" /> t
                join (
                    select
                    <foreach collection="__first_update_map__" index="__col__" item="__val__" separator=", ">
                        <bind name="__us_col__" value="@com.pudonghot.tigon.mybatis.util.EntityUtils@quotationWrap(__col__)" />
                        null ${__us_col__}
                    </foreach>

                    <foreach item="__model__" collection="__models__" separator=" ">
                        union select
                        <foreach collection="@com.pudonghot.tigon.mybatis.util.EntityUtils@batchUpdateMap(__model__)" item="__val__" separator=", ">
                            <include refid="Tigon.__val__" />
                        </foreach>
                    </foreach>
                ) tt
                on t.<include refid="primaryKey" /> = tt.<include refid="primaryKey" />

                set
                <foreach collection="__first_update_map__"
                         index="__col__"
                         item="__val__" separator=", ">
                    <bind name="__us_col__" value="@com.pudonghot.tigon.mybatis.util.EntityUtils@quotationWrap(__col__)" />
                    <choose>
                        <when test="__val__ instanceof com.pudonghot.tigon.mybatis.SqlParam and __val__.isIgnoreNull()">
                            t.${__us_col__} = ifnull(tt.${__us_col__}, t.${__us_col__})
                        </when>
                        <otherwise>
                            t.${__us_col__} = tt.${__us_col__}
                        </otherwise>
                    </choose>
                </foreach>
            </when>
            <otherwise>
                update <include refid="table" />
                set
                <choose>
                    <when test="_parameter.containsKey(&quot;__col__&quot;)">
                        <include refid="Tigon.__updateCol__" />
                    </when>
                    <when test="__model__ instanceof java.util.Map">
                        <foreach collection="__model__" index="__col__" item="__val__" separator=", ">
                            <include refid="Tigon.__updateCol__" />
                        </foreach>
                    </when>
                    <otherwise>
                        <if test="__model__ instanceof com.pudonghot.tigon.mybatis.BasicEntity">
                            <bind name="__before_update_dummy__" value="__model__.beforeUpdate()" />
                        </if>
                        <foreach collection="@com.pudonghot.tigon.mybatis.util.EntityUtils@updateMap(__model__)"
                                 index="__col__" item="__val__" separator=", ">
                            <include refid="Tigon.__updateCol__" />
                        </foreach>
                    </otherwise>
                </choose>

                <choose>
                    <when test="_parameter.containsKey(&quot;__search__&quot;)">
                        <include refid="Tigon.search" />
                    </when>
                    <otherwise>
                        <bind name="__primary_key_val__" value="@com.pudonghot.tigon.mybatis.util.EntityUtils@primaryKeyValue(__model__)" />
                        where <include refid="primaryKey" /> = #{__primary_key_val__}
                    </otherwise>
                </choose>
            </otherwise>
        </choose>
    </sql>
    <!--/ Update -->

    <!-- Set Cols null -->
    <sql id="setNull">
        update
        <include refid="table" />
        set
        <choose>
        <when test="_parameter.containsKey(&quot;__cols__&quot;)">
            <foreach item="__col__" collection="__cols__" separator=", ">
                <bind name="__us_col__" value="@com.pudonghot.tigon.mybatis.util.EntityUtils@quotationWrap(__col__)" />
                ${__us_col__} = null
            </foreach>
        </when>
        <otherwise>
            <bind name="__us_col__" value="@com.pudonghot.tigon.mybatis.util.EntityUtils@quotationWrap(__col__)" />
            ${__us_col__} = null
        </otherwise>
        </choose>
        <include refid="Tigon.search" />
    </sql>
    <!--/ Set Cols null -->

    <!-- Delete -->
    <sql id="delete">
        delete from
        <include refid="table" />
        <include refid="Tigon.search" />
    </sql>
    <!--/ Delete -->

    <!-- Exists -->
    <sql id="exists">
        select exists (
            select * from
            <include refid="table" />
            <include refid="Tigon.npSearch" />
        )
    </sql>

    <sql id="exists" databaseId="oracle">
        select count(*) from
        <include refid="table" />
        <include refid="Tigon.npSearch" />
    </sql>
    <!--/ Exists -->

    <!-- Find One -->
    <sql id="find">
        select
        <include refid="Tigon.distinct" />
        <include refid="colsOfFind" />
        from
        <include refid="table" />
        <include refid="Tigon.search" />
    </sql>
    <!--/ Find One -->

    <!-- List -->
    <sql id="list">
        select
        <include refid="Tigon.distinct" />
        <include refid="colsOfList" />
        from
        <include refid="table" />
        <include refid="Tigon.search" />
    </sql>

    <!-- List for oracle pagination -->
    <sql id="list" databaseId="oracle">
        select
        <include refid="Tigon.distinct" />
        *
        <if test="__search__ instanceof com.pudonghot.tigon.mybatis.Search and (__search__.offset() != null or __search__.limit() != null)">
            from (select <include refid="colsOfList" />,
            row_number() over (
            <choose>
                <when test="__search__.hasOrder()">
                    <include refid="Tigon.orderBy" />
                </when>
                <otherwise>
                    order by 1
                </otherwise>
            </choose>
            ) - 1 row_number__
        </if>

        from <include refid="table" />

        <choose>
            <when test="__search__ instanceof com.pudonghot.tigon.mybatis.Search">
                <if test="__search__.hasCriterion()">
                    where <include refid="Tigon.assemble" />
                </if>
            </when>
            <when test="__search__ != null">
                where <include refid="primaryKey" /> = #{__search__}
            </when>
        </choose>

        <!-- No offset and limit, place order by here -->
        <if test="__search__ instanceof com.pudonghot.tigon.mybatis.Search and __search__.offset() == null and __search__.limit() == null">
            <include refid="Tigon.orderBy" />
        </if>

        <if test="__search__ instanceof com.pudonghot.tigon.mybatis.Search and (__search__.offset() != null or __search__.limit() != null)">
            ) t
            where
            <choose>
            <when test="__search__.offset() != null and __search__.limit() != null">
                <bind name="__offset__" value="__search__.offset()" />
                <bind name="__limit__" value="__search__.limit()" />
                <![CDATA[
                  row_number__ >= #{__offset__} and row_number__ < #{__offset__} + #{__limit__}
                ]]>
            </when>
            <when test="__search__.offset() != null">
                <bind name="__offset__" value="__search__.offset()" />
                <![CDATA[
                  row_number__ >= #{__offset__}
                ]]>
            </when>
            <when test="__search__.limit() != null">
                <bind name="__limit__" value="__search__.limit()" />
                <![CDATA[
                  row_number__ < #{__limit__}
                ]]>
            </when>
            </choose>
        </if>
    </sql>
    <!--/ List -->

    <!-- Select Single Col -->
    <sql id="selectCol">
        <bind name="__us_col__" value="@com.pudonghot.tigon.mybatis.util.EntityUtils@quotationWrap(__col__)" />
        select
        <include refid="Tigon.distinct" />
        ${__us_col__}
        from
        <include refid="table" />
        <include refid="Tigon.search" />
    </sql>
    <!--/ Select Col -->

    <!-- Select -->
    <sql id="select">
        select
        ${__select_expr__}
        from
        <include refid="table" />
        <include refid="Tigon.search" />
    </sql>
    <!--/ Select -->

    <!-- Count -->
    <sql id="count">
        select count(*) from
        <include refid="table" />
        <include refid="Tigon.npSearch" />
    </sql>
    <!--/ Count -->

    <sql id="__updateCol__">
        <bind name="__us_col__" value="@com.pudonghot.tigon.mybatis.util.EntityUtils@quotationWrap(__col__)" />
        ${__us_col__} = <include refid="Tigon.__val__" />
    </sql>

    <sql id="__val__">
        <choose>
            <when test="__val__ instanceof com.pudonghot.tigon.mybatis.SqlParam">
                <choose>
                    <when test="__val__.isRaw()">
                        ${__val__.value}
                    </when>
                    <otherwise>
                        #{__val__.value}
                    </otherwise>
                </choose>
            </when>
            <otherwise>
                #{__val__}
            </otherwise>
        </choose>
    </sql>

</mapper>
